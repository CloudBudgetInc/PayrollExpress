    <fields>
        <fullName>sdfs__Processed_Date_Time_Epoch__c</fullName>
        <deprecated>false</deprecated>
        <externalId>false</externalId>
        <formula>(sdfs__Processed_Date_Time__c -  DATETIMEVALUE(&quot;1970-01-01 00:00:00&quot;)) * (24 * 60 * 60)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Processed Date / Time Epoch</label>
        <precision>18</precision>
        <required>false</required>
        <scale>2</scale>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
