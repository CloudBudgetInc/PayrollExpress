    <fields>
        <fullName>sdfs__All_Sharing_Removed__c</fullName>
        <defaultValue>false</defaultValue>
        <deprecated>false</deprecated>
        <externalId>false</externalId>
        <inlineHelpText>Ture if all FormulaShare sharing for this record has been removed. When this is the case, total records shared tracked in FormulaShare usage will be reduced by 1</inlineHelpText>
        <label>All Sharing Removed</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>sdfs__Assessment_Type_Override__c</fullName>
        <deprecated>false</deprecated>
        <description>Written for flow logs to specify Assessment Type explicitly</description>
        <externalId>false</externalId>
        <label>Assessment Type Override</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>sdfs__Assessment_Type__c</fullName>
        <deprecated>false</deprecated>
        <externalId>false</externalId>
        <formula>IF(!ISBLANK(sdfs__Assessment_Type_Override__c), sdfs__Assessment_Type_Override__c,
IF( sdfs__Context__c = &apos;Trigger&apos;, &apos;Transaction Safe&apos;, &apos;Full Assessment&apos;)
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <inlineHelpText>&quot;Full Assessment&quot; indicates all rules were evaluated for this record during sharing assessment, and is the default mode for batch assessment, as well as being an option for assessment triggered by flows. &quot;Transaction Safe&quot; means only rules which could be evaluated without querying and iterating collections of records were applied, and is the default for triggers and an option in flows</inlineHelpText>
        <label>Assessment Type</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>sdfs__Batch_Log_Id__c</fullName>
        <deprecated>false</deprecated>
        <externalId>false</externalId>
        <formula>CASESAFEID(sdfs__FormulaShare_Batch_Log__r.Id)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Batch Log Id</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>sdfs__Context_Detail__c</fullName>
        <deprecated>false</deprecated>
        <description>Indicates operation type which initiated sharing assessment: &quot;Record Triggered Flow&quot;, &quot;Apex Trigger&quot;, &quot;Requested via Flow&quot;, &quot;Requested via Apex&quot;, &quot;Full Recalculation Batch&quot;, &quot;Manually Initiated Batch&quot; and &quot;Targeted Calculation Job&quot;</description>
        <externalId>false</externalId>
        <label>Context Detail</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>sdfs__Context__c</fullName>
        <deprecated>false</deprecated>
        <externalId>false</externalId>
        <formula>IF(!ISBLANK(sdfs__Context_Detail__c), sdfs__Context_Detail__c,
IF(ISBLANK(sdfs__FormulaShare_Batch_Log__c), &quot;Trigger&quot;, &quot;Batch&quot;)
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Context</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
