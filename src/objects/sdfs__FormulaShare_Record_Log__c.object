    <fields>
        <fullName>sdfs__All_Deleted_Sharing_Successful__c</fullName>
        <deprecated>false</deprecated>
        <externalId>false</externalId>
        <formula>sdfs__Number_Processed_Record_Share_Deletes__c = sdfs__Number_Successful_Record_Share_Deletes__c</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>All Deleted Sharing Successful</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
