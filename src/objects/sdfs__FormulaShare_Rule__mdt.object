    </fields>
    <fields>
        <fullName>sdfs__Sharing_Reason__c</fullName>
        <caseSensitive>false</caseSensitive>
        <deprecated>false</deprecated>
        <description>Sharing reason associated with this rule (for custom objects only). The Apex Sharing Reason set here must exist on the shared object, and all records shared through this rule will be shared with this reason</description>
        <externalId>false</externalId>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>Sharing Reason</label>
        <length>255</length>
        <required>false</required>
        <type>Text</type>
        <unique>true</unique>
    </fields>
    <label>FormulaShare Rule</label>
    <listViews>
        <fullName>sdfs__All_Rules</fullName>
        <columns>MasterLabel</columns>
        <columns>sdfs__Object_Shared__c</columns>
        <columns>sdfs__Share_With__c</columns>
        <columns>sdfs__Shared_To__c</columns>
        <columns>sdfs__Sharing_Reason__c</columns>
        <columns>sdfs__Access_Level__c</columns>
        <columns>sdfs__Active__c</columns>
        <filterScope>Everything</filterScope>
        <label>All Rules</label>
    </listViews>
    <pluralLabel>FormulaShare Rules</pluralLabel>
    <validationRules>
        <fullName>sdfs__Account_related_object_access_case</fullName>
        <active>true</active>
        <errorConditionFormula>sdfs__Object_Shared__r.DeveloperName = &apos;Account&apos; &amp;&amp; ISBLANK(TEXT(sdfs__Case_Access__c))</errorConditionFormula>
        <errorDisplayField>sdfs__Case_Access__c</errorDisplayField>
        <errorMessage>Case Access must be set for account sharing. Select a level of sharing which is the same or more permissive than the org-wide default for cases</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>sdfs__Account_related_object_access_contact</fullName>
        <active>true</active>
        <errorConditionFormula>sdfs__Object_Shared__r.DeveloperName = &apos;Account&apos; &amp;&amp; ISBLANK(TEXT(sdfs__Contact_Access__c))</errorConditionFormula>
        <errorDisplayField>sdfs__Contact_Access__c</errorDisplayField>
        <errorMessage>Contact Access must be set for account sharing. If organisation-wide default sharing for Contact is &quot;Controlled by Parent&quot; select this as the option, otherwise select a level of sharing which is the same or more permissive than the org-wide default</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>sdfs__Account_related_object_access_opps</fullName>
        <active>true</active>
        <errorConditionFormula>sdfs__Object_Shared__r.DeveloperName = &apos;Account&apos; &amp;&amp; ISBLANK(TEXT(sdfs__Opportunity_Access__c))</errorConditionFormula>
        <errorDisplayField>sdfs__Opportunity_Access__c</errorDisplayField>
        <errorMessage>Opportunity Access must be set for account sharing. Select a level of sharing which is the same or more permissive than the org-wide default for opportunities</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>sdfs__Sharing_reason_must_end_underscores_c</fullName>
        <active>true</active>
        <errorConditionFormula>!ISBLANK( sdfs__Sharing_Reason__c ) &amp;&amp;  RIGHT( sdfs__Sharing_Reason__c , 3) != &apos;__c&apos;</errorConditionFormula>
        <errorDisplayField>sdfs__Sharing_Reason__c</errorDisplayField>
        <errorMessage>Sharing reasons must be appended with &quot;__c&quot;</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>sdfs__Users_must_be_shared_to_by_Id_field</fullName>
        <active>true</active>
        <errorConditionFormula>ISPICKVAL(sdfs__Shared_To_Field_Type__c,&apos;Name&apos;) &amp;&amp;  ISPICKVAL(sdfs__Share_With__c,&apos;Users&apos;)</errorConditionFormula>
        <errorDisplayField>sdfs__Shared_To_Field_Type__c</errorDisplayField>
        <errorMessage>Rules sharing to users must be based on a field returning the user Id (either a lookup or formula field)</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
