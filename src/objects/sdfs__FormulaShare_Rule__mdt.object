        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>Share With</label>
        <required>true</required>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Users</fullName>
                    <default>true</default>
                    <label>Users</label>
                </value>
                <value>
                    <fullName>Roles</fullName>
                    <default>false</default>
                    <label>Roles</label>
                </value>
                <value>
                    <fullName>Roles and Internal Subordinates</fullName>
                    <default>false</default>
                    <label>Roles and Internal Subordinates</label>
                </value>
                <value>
                    <fullName>Roles, Internal and Portal Subordinates</fullName>
                    <default>false</default>
                    <label>Roles, Internal and Portal Subordinates</label>
                </value>
                <value>
                    <fullName>Public Groups</fullName>
                    <default>false</default>
                    <label>Public Groups</label>
                </value>
                <value>
                    <fullName>Managers of Users</fullName>
                    <default>false</default>
                    <label>Managers of Users</label>
                </value>
                <value>
                    <fullName>Users and Manager Subordinates</fullName>
                    <default>false</default>
                    <label>Users and Manager Subordinates</label>
                </value>
                <value>
                    <fullName>Default Account Teams of Users</fullName>
                    <default>false</default>
                    <label>Default Account Teams of Users</label>
                </value>
                <value>
                    <fullName>Default Opportunity Teams of Users</fullName>
                    <default>false</default>
                    <label>Default Opportunity Teams of Users</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>sdfs__Shared_To_Field_Type__c</fullName>
        <deprecated>false</deprecated>
        <externalId>false</externalId>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>&quot;Shared To Field&quot; can contain either the 15 or 18 digit record id of the user, group or role to find the right users (select &quot;Id&quot; if so), or can contain the relevant Role Name or Group Name (select &quot;Name&quot; if this is the case)</inlineHelpText>
        <label>Shared To Field Type</label>
        <required>false</required>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Id</fullName>
                    <default>true</default>
                    <label>Id</label>
                </value>
                <value>
                    <fullName>Name</fullName>
                    <default>false</default>
                    <label>Name</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
