        <externalId>false</externalId>
        <inlineHelpText>Number of records processed in this batch which were previously shared by FormulaShare and have had updates made to this sharing. These records contribute towards the limit of total number of records shared</inlineHelpText>
        <label>Records w/ Sharing Updated</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>sdfs__Related_Log_Required_for_Test_Class__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <deprecated>false</deprecated>
        <externalId>false</externalId>
        <label>Related Log (Required for Test Class)</label>
        <referenceTo>sdfs__FormulaShare_Log__c</referenceTo>
        <relationshipName>FormulaShare_Logs</relationshipName>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>sdfs__Status__c</fullName>
        <deprecated>false</deprecated>
        <externalId>false</externalId>
        <formula>IF(sdfs__Batches_Processed__c = 0 &amp;&amp; sdfs__Exception_Type__c != NULL, &apos;Skipped&apos;, 
    IF((sdfs__Failed_Batches__c = &apos;None&apos; || ISBLANK(sdfs__Failed_Batches__c)), &apos;Success&apos;,
        IF((sdfs__Batches_Failed__c &gt; 0 &amp;&amp; sdfs__Batches_Failed__c &lt; sdfs__Batches_Processed__c), &apos;Partial Success&apos;,&apos;Failed&apos;)
    )
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Status</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>sdfs__Type_In_Scope__c</fullName>
