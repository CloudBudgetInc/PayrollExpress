        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>sdfs__Records_w_Sharing_Still_In_Place__c</fullName>
        <deprecated>false</deprecated>
        <externalId>false</externalId>
        <inlineHelpText>Number of records processed in this batch which were previously shared by FormulaShare and have had no updates made to this sharing. These records contribute towards the limit of total number of records shared</inlineHelpText>
        <label>Records w/ Sharing Still In Place</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <trackTrending>false</trackTrending>
        <type>Number</type>
