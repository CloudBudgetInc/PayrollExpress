    <fields>
        <fullName>sdfs__Processing_Time_Seconds__c</fullName>
        <deprecated>false</deprecated>
        <externalId>false</externalId>
        <formula>IF(!ISBLANK( sdfs__Processing_Started_Milliseconds__c ) &amp;&amp; !ISBLANK( sdfs__Processing_Finished_Milliseconds__c ), 
( sdfs__Processing_Finished_Milliseconds__c - sdfs__Processing_Started_Milliseconds__c ) / 1000,
NULL)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Processing Time (Seconds)</label>
        <precision>18</precision>
        <required>false</required>
        <scale>3</scale>
        <trackTrending>false</trackTrending>
        <type>Number</type>
