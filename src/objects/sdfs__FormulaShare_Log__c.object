    <fields>
        <fullName>sdfs__Records_Not_Shared_by_FormulaShare__c</fullName>
        <deprecated>false</deprecated>
        <externalId>false</externalId>
        <inlineHelpText>Number of records processed in this batch which were not shared by FormulaShare, either prior to the batch running or afterwards. These records will not contribute towards the limit of total number of records shared</inlineHelpText>
        <label>Records Not Shared by FormulaShare</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
